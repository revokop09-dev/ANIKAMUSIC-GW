def smallcaps(text):
    chars = {'a': 'ᴀ', 'b': 'ʙ', 'c': 'ᴄ', 'd': 'ᴅ', 'e': 'ᴇ', 'f': 'ғ', 'g': 'ɢ', 'h': 'ʜ', 'i': 'ɪ', 'j': 'ᴊ', 'k': 'ᴋ', 'l': 'ʟ', 'm': 'ᴍ', 'n': 'ɴ', 'o': 'ᴏ', 'p': 'ᴘ', 'q': 'ǫ', 'r': 'ʀ', 's': 's', 't': 'ᴛ', 'u': 'ᴜ', 'v': 'ᴠ', 'w': 'ᴡ', 'x': 'x', 'y': 'ʏ', 'z': 'ᴢ', 'A': 'ᴀ', 'B': 'ʙ', 'C': 'ᴄ', 'D': 'ᴅ', 'E': 'ᴇ', 'F': 'ғ', 'G': 'ɢ', 'H': 'ʜ', 'I': 'ɪ', 'J': 'ᴊ', 'K': 'ᴋ', 'L': 'ʟ', 'M': 'ᴍ', 'N': 'ɴ', 'O': 'ᴏ', 'P': 'ᴘ', 'Q': 'ǫ', 'R': 'ʀ', 'S': 's', 'T': 'ᴛ', 'U': 'ᴜ', 'V': 'ᴠ', 'W': 'ᴡ', 'X': 'x', 'Y': 'ʏ', 'Z': 'ᴢ'}
    return ''.join(chars.get(c, c) for c in str(text))

def get_raw_markup(markup):
    if hasattr(markup, 'inline_keyboard'):
        raw_kb = []
        for row in markup.inline_keyboard:
            raw_row = []
            for btn in row:
                raw_btn = {"text": btn.text}
                if btn.callback_data: raw_btn["callback_data"] = btn.callback_data
                if btn.url: raw_btn["url"] = btn.url
                raw_row.append(raw_btn)
            raw_kb.append(raw_row)
        return raw_kb
    return markup

async def inject_premium_markup(chat_id, message_id, markup):
    try:
        markup = get_raw_markup(markup)
        token = getattr(config, "BOT_TOKEN", getattr(app, "bot_token", None))
        url = f"https://api.telegram.org/bot{token}/editMessageReplyMarkup"
        payload = {"chat_id": chat_id, "message_id": message_id, "reply_markup": {"inline_keyboard": markup}}
        async with aiohttp.ClientSession() as session:
            await session.post(url, json=payload)
    except Exception as e:
        pass

async def get_watermark():
    data = await watermark_db.find_one({"type": "current"})
    return data["text"] if data else DEFAULT_WATERMARK

async def get_active_theme():
    data = await theme_db.find_one({"type": "active"})
    return data if data else {"text": DEFAULT_THEME, "pic": DEFAULT_PIC, "warn": ""}

# --- COMMANDS ---

# 1. SET WATERMARK
@app.on_message(filters.command(["setwatermark", "watermark"], prefixes=["/", ".", "!"]) & filters.user(list(SUDOERS)))
async def set_watermark_cmd(client, message: Message):
    if len(message.command) < 2:
        return await message.reply(f"<emoji id='5999100917645841519'>⚠️</emoji> {smallcaps('Please provide the watermark text!')}\n**Example:** `.setwatermark 𝐒 𝛖 𝐝 ֟፝ᥱ 𝛆 𝛒`")
    
    new_watermark = message.text.split(None, 1)[1]
    await watermark_db.update_one({"type": "current"}, {"$set": {"text": new_watermark}}, upsert=True)
    await message.reply(f"<emoji id='6001132493011425597'>✅</emoji> **{smallcaps('Watermark Updated Successfully!')}**\n\n<blockquote>**{smallcaps('New Watermark:')}** `{new_watermark}`</blockquote>")

