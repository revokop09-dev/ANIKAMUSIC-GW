# 3. INTERACTIVE SETUP INITIATOR (.setplyar)
@app.on_message(filters.command(["setplyar", "plyarset"], prefixes=["/", ".", "!"]) & filters.user(list(SUDOERS)))
async def start_interactive_setup(client, message: Message):
    user_id = message.from_user.id
    chat_id = message.chat.id
    setup_states[(chat_id, user_id)] = {"step": 1, "pic": "", "code": "", "warn": ""}
    
    text = (
        f"<emoji id='5999063078983964465'>🎨</emoji> **{smallcaps('Player Theme Setup Started')}**\n\n"
        f"<blockquote>{smallcaps('Step 1: Please send me the Catbox URL (or any direct image/video link) for your player background.')}</blockquote>\n\n"
        f"*(Type `.cancel` anytime to stop the setup)*"
    )
    await message.reply(text)

# 4. CANCEL SETUP
@app.on_message(filters.command(["cancel"], prefixes=["/", ".", "!"]) & filters.user(list(SUDOERS)))
async def cancel_setup(client, message: Message):
    key = (message.chat.id, message.from_user.id)
    if key in setup_states:
        del setup_states[key]
        await message.reply(f"<emoji id='5999100917645841519'>❌</emoji> **{smallcaps('Player setup cancelled.')}**")

# 5. STATE MACHINE (Handles the step-by-step replies)
@app.on_message(filters.text & filters.user(list(SUDOERS)), group=10)
async def handle_setup_steps(client, message: Message):
    key = (message.chat.id, message.from_user.id)
    
    # Check if user is in setup mode and not typing a command
    if key not in setup_states or message.text.startswith(("/", ".", "!")):
        return
        
    state = setup_states[key]
    step = state["step"]
    
    if step == 1:
        state["pic"] = message.text.strip()
        state["step"] = 2
        text = (
            f"<emoji id='6001533441093408240'>📝</emoji> **{smallcaps('Step 1 Complete!')}**\n\n"
            f"<blockquote>{smallcaps('Step 2: Now send me the HTML format code for the player.')}\n\n"
            f"{smallcaps('Use these variables in your code:')}\n"
            f"`{{0}}` - {smallcaps('Song Link')}\n"
            f"`{{1}}` - {smallcaps('Song Title')}\n"
            f"`{{2}}` - {smallcaps('Duration')}\n"
            f"`{{3}}` - {smallcaps('Requested By')}\n"
            f"`{{4}}` - {smallcaps('Watermark')}</blockquote>"
        )
        await message.reply(text)
        
    elif step == 2:
        state["code"] = message.text.strip()
        state["step"] = 3
        text = (
            f"<emoji id='5375434433195164090'>✨</emoji> **{smallcaps('Step 2 Complete!')}**\n\n"
            f"<blockquote>{smallcaps('Step 3: Finally, send the Premium Warning or Description text you want to show below the player.')}\n\n"
            f"*(If you do not want a warning, simply reply with `skip`)*</blockquote>"
        )
        await message.reply(text)
        
    elif step == 3:
        warn_text = message.text.strip()
        if warn_text.lower() == 'skip':
            warn_text = ""
            
        # Save to database
        await theme_db.update_one(
            {"type": "active"}, 
            {"$set": {"text": state["code"], "pic": state["pic"], "warn": warn_text}}, 
            upsert=True
        )
        
        # Clear state
        del setup_states[key]
        
        success_text = f"<emoji id='6001132493011425597'>🎉</emoji> **{smallcaps('Theme Successfully Saved!')}**\n\n<blockquote>{smallcaps('Your new player design has been applied instantly. Zero restart required. Type `.editplyar` to preview it.')}</blockquote>"
        await message.reply(success_text)

