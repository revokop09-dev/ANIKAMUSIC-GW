@app.on_message(filters.command(["editplyar", "plyaredit"], prefixes=["/", ".", "!"]) & filters.user(list(SUDOERS)))
async def view_player_theme(client, message: Message):
    theme = await get_active_theme()
    watermark = await get_watermark()
    
    # Dummy data for preview
    try:
        preview_text = theme["text"].format(
            "https://t.me/hehe_stalker", 
            "Dummy Song Title Preview", 
            "03:45", 
            message.from_user.mention, 
            watermark
        )
    except Exception as e:
        preview_text = f"<emoji id='5999100917645841519'>⚠️</emoji> **{smallcaps('Formatting Error in your Theme Code!')}**\n\n{str(e)}"

    if theme["warn"]:
        preview_text += f"\n\n<blockquote><emoji id='5999210495146465994'>⚠️</emoji> **{smallcaps('Premium Notice:')}**\n{theme['warn']}</blockquote>"
        
    markup = InlineKeyboardMarkup([
        [
            InlineKeyboardButton(f"💧 {smallcaps('Set Watermark')}", switch_inline_query_current_chat=".setwatermark "),
            InlineKeyboardButton(f"🎨 {smallcaps('New Theme')}", callback_data="btn_new_theme")
        ],
        [
            InlineKeyboardButton(f"🗑 {smallcaps('Remove Theme')}", callback_data="btn_rm_theme"),
            InlineKeyboardButton(f"❌ {smallcaps('Close')}", callback_data="btn_close_panel")
        ]
    ])
    
    header = f"<emoji id='6080202089311507876'>😎</emoji> **{smallcaps('Current Player Theme Preview')}**\n\n"
    
    run = await message.reply_photo(
        photo=theme["pic"], 
        caption=header + preview_text, 
    )
    await inject_premium_markup(message.chat.id, run.id, markup)

# Callback queries for the preview panel buttons
@app.on_callback_query(filters.regex("^(btn_new_theme|btn_rm_theme|btn_close_panel)$"))
async def theme_panel_callbacks(client, cq):
    if cq.data == "btn_close_panel":
        await cq.message.delete()
    
    elif cq.data == "btn_new_theme":
        await cq.message.delete()
        # Trigger the setup command logic directly
        user_id = cq.from_user.id
        chat_id = cq.message.chat.id
        setup_states[(chat_id, user_id)] = {"step": 1, "pic": "", "code": "", "warn": ""}
        text = f"<emoji id='5999063078983964465'>🎨</emoji> **{smallcaps('Player Theme Setup Started')}**\n\n<blockquote>{smallcaps('Step 1: Please send me the Catbox URL for your player background.')}</blockquote>\n\n*(Type `.cancel` anytime to stop)*"
        await client.send_message(chat_id, text)
        
    elif cq.data == "btn_rm_theme":
        await theme_db.delete_one({"type": "active"})
        await cq.answer("Custom theme removed! Reverted to default.", show_alert=True)
        await cq.message.delete()
      
